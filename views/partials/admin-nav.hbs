<style>
/* Admin Navigation Styles */
.admin-nav {
  background: var(--glass-bg);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--glass-border);
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
}

.nav-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-xl);
  max-width: 1400px;
  margin: 0 auto;
}

.nav-brand .logo {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  text-decoration: none;
  color: var(--white);
  font-weight: 700;
  font-size: 1.25rem;
}

.nav-brand .logo i {
  color: var(--accent);
  font-size: 1.5rem;
}

