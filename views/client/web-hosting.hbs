    <div class="ssl-item">
      <div class="ssl-info">
        <div class="ssl-name">${cert.name}</div>
        <div class="ssl-meta">
          Issuer: ${cert.issuer || 'Unknown'} • 
          Expires: ${cert.expirationDate ? new Date(cert.expirationDate).toLocaleDateString() : 'Unknown'}
        </div>
      </div>
      <div class="ssl-actions">
        <button class="btn btn-outline btn-sm" onclick="manageSSL('${cert.id}')">
          <i class="fas fa-cog"></i>
        </button>
        <button class="btn btn-danger btn-sm" onclick="deleteSSL('${cert.id}')">
          <i class="fas fa-trash"></i>
        </button>
      </div>
    </div>
  `).join('');
}

function openBackups() {
  if (!currentSubscription) return;
  
  document.getElementById('backupsModal').classList.add('show');
  document.body.style.overflow = 'hidden';
  
  loadBackups();
}

function closeBackupsModal() {
  document.getElementById('backupsModal').classList.remove('show');
  document.body.style.overflow = '';
}

async function loadBackups() {
  if (!currentSubscription) return;
  
  try {
    const response = await fetch(`/api/plesk/backups?subscriptionId=${currentSubscription.id}`, {
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('token')}`
      }
    });
    
    const data = await response.json();
    
