  }
}

function renderEmailAccounts(emails) {
  const list = document.getElementById('emailList');
  
  if (emails.length === 0) {
    list.innerHTML = '<p class="text-center">No email accounts found</p>';
    return;
  }
  
  list.innerHTML = emails.map(email => `
    <div class="email-item">
      <div class="email-info">
        <div class="email-name">${email.name}</div>
        <div class="email-meta">
          ${email.name}@${currentSubscription.domain || 'domain.com'} • 
          Quota: ${email.mailbox_quota === -1 ? 'Unlimited' : email.mailbox_quota + ' MB'}
        </div>
      </div>
      <div class="email-actions">
        <button class="btn btn-outline btn-sm" onclick="manageEmail('${email.id}')">
          <i class="fas fa-cog"></i>
        </button>
        <button class="btn btn-danger btn-sm" onclick="deleteEmail('${email.id}')">
          <i class="fas fa-trash"></i>
        </button>
      </div>
    </div>
  `).join('');
}

function openSSLCertificates() {
  if (!currentSubscription) return;
  
  document.getElementById('sslModal').classList.add('show');
  document.body.style.overflow = 'hidden';
  
  loadSSLCertificates();
}

function closeSSLModal() {
  document.getElementById('sslModal').classList.remove('show');
  document.body.style.overflow = '';
}

