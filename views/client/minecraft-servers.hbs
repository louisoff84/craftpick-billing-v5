<script>
let currentServer = null;
let servers = [];
let consoleInterval = null;

// Load servers on page load
document.addEventListener('DOMContentLoaded', () => {
  loadServers();
  setupEventListeners();
});

async function loadServers() {
  try {
    showLoadingState();
    const response = await fetch('/api/pterodactyl/servers', {
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('token')}`
      }
    });
    
    const data = await response.json();
    
    if (data.success) {
      servers = data.data;
      renderServers();
      updateStats();
      hideLoadingState();
    } else {
      showError('Failed to load servers');
      hideLoadingState();
    }
  } catch (error) {
    console.error('Error loading servers:', error);
    showError('Error loading servers');
    hideLoadingState();
  }
}

function renderServers() {
  const grid = document.getElementById('serversGrid');
  const searchTerm = document.getElementById('serverSearch').value.toLowerCase();
  const statusFilter = document.getElementById('statusFilter').value;
  const typeFilter = document.getElementById('typeFilter').value;
  
  let filteredServers = servers.filter(server => {
    const matchesSearch = server.name.toLowerCase().includes(searchTerm);
    const matchesStatus = !statusFilter || server.status === statusFilter;
    const matchesType = !typeFilter || server.type === typeFilter;
    
    return matchesSearch && matchesStatus && matchesType;
  });
  
  if (filteredServers.length === 0) {
    showEmptyState();
    return;
  }
  
  hideEmptyState();
  
  grid.innerHTML = filteredServers.map(server => `
    <div class="server-card" onclick="openServerDetails('${server.id}')">
      <div class="server-header">
        <div>
          <div class="server-name">${server.name}</div>
          <div class="server-status status-${server.status}">${getStatusText(server.status)}</div>
        </div>
      </div>
      <div class="server-info">
        <div class="server-specs">
          <div class="spec-item">
            <label>RAM:</label>
            <span class="spec-value">${server.limits.memory} MB</span>
          </div>
          <div class="spec-item">
            <label>CPU:</label>
            <span class="spec-value">${server.limits.cpu}%</span>
          </div>
          <div class="spec-item">
            <label>Stockage:</label>
            <span class="spec-value">${server.limits.disk} MB</span>
          </div>
          <div class="spec-item">
            <label>Type:</label>
            <span class="spec-value">${server.type || 'Minecraft'}</span>
          </div>
        </div>
      </div>
      <div class="server-actions">
        <button class="btn btn-success" onclick="event.stopPropagation(); quickAction('${server.id}', 'start')">
          <i class="fas fa-play"></i>
        </button>
        <button class="btn btn-warning" onclick="event.stopPropagation(); quickAction('${server.id}', 'restart')">
          <i class="fas fa-redo"></i>
        </button>
        <button class="btn btn-danger" onclick="event.stopPropagation(); quickAction('${server.id}', 'stop')">
          <i class="fas fa-stop"></i>
        </button>
      </div>
    </div>
  `).join('');
}

function updateStats() {
  const totalServers = servers.length;
  const onlineServers = servers.filter(s => s.status === 'running').length;
  const offlineServers = servers.filter(s => s.status === 'offline').length;
  
  document.getElementById('totalServers').textContent = totalServers;
  document.getElementById('onlineServers').textContent = onlineServers;
  document.getElementById('offlineServers').textContent = offlineServers;
  
  // Calculate total RAM usage
  const totalRAM = servers.reduce((sum, server) => sum + (server.resources?.memory || 0), 0);
  document.getElementById('totalRAM').textContent = `${Math.round(totalRAM / 1024)} GB`;
}

function getStatusText(status) {
  const statusMap = {
    'running': 'En ligne',
    'offline': 'Hors ligne',
    'starting': 'Démarrage',
    'stopping': 'Arrêt',
    'restarting': 'Redémarrage'
  };
  return statusMap[status] || status;
}

async function openServerDetails(serverId) {
  try {
    const response = await fetch(`/api/pterodactyl/servers/${serverId}`, {
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('token')}`
      }
    });
    
    const data = await response.json();
    
    if (data.success) {
      currentServer = data.data;
      showServerModal();
      updateServerDetails();
      startResourceMonitoring();
    } else {
      showError('Failed to load server details');
    }
  } catch (error) {
    console.error('Error loading server details:', error);
    showError('Error loading server details');
  }
}

function showServerModal() {
  document.getElementById('serverModal').classList.add('show');
  document.body.style.overflow = 'hidden';
}

function closeServerModal() {
  document.getElementById('serverModal').classList.remove('show');
  document.body.style.overflow = '';
  currentServer = null;
  stopResourceMonitoring();
}

function updateServerDetails() {
  if (!currentServer) return;
  
  document.getElementById('detailName').textContent = currentServer.name;
  document.getElementById('detailUUID').textContent = currentServer.uuid;
  document.getElementById('detailStatus').textContent = getStatusText(currentServer.status);
  document.getElementById('detailNode').textContent = currentServer.node || 'Unknown';
  
  // Update resource bars
  updateResourceBars();
}

function updateResourceBars() {
  if (!currentServer || !currentServer.resources) return;
  
  const resources = currentServer.resources;
  
  // CPU
  const cpuPercent = resources.cpu_absolute || 0;
  document.getElementById('cpuBar').style.width = `${cpuPercent}%`;
  document.getElementById('cpuText').textContent = `${cpuPercent}%`;
  
  // RAM
  const ramUsed = resources.memory_bytes || 0;
  const ramTotal = currentServer.limits.memory * 1024 * 1024;
  const ramPercent = (ramUsed / ramTotal) * 100;
  document.getElementById('ramBar').style.width = `${ramPercent}%`;
  document.getElementById('ramText').textContent = `${Math.round(ramUsed / 1024 / 1024)} MB / ${Math.round(ramTotal / 1024 / 1024)} MB`;
  
  // Disk
  const diskUsed = resources.disk_bytes || 0;
  const diskTotal = currentServer.limits.disk * 1024 * 1024;
  const diskPercent = (diskUsed / diskTotal) * 100;
  document.getElementById('diskBar').style.width = `${diskPercent}%`;
  document.getElementById('diskText').textContent = `${Math.round(diskUsed / 1024 / 1024)} MB / ${Math.round(diskTotal / 1024 / 1024)} MB`;
}

function startResourceMonitoring() {
  if (!currentServer) return;
  
  stopResourceMonitoring();
  
  consoleInterval = setInterval(async () => {
    try {
      const response = await fetch(`/api/pterodactyl/servers/${currentServer.id}/resources`, {
        headers: {
          'Authorization': `Bearer ${localStorage.getItem('token')}`
        }
      });
      
      const data = await response.json();
      
      if (data.success) {
        currentServer.resources = data.data.attributes;
        updateResourceBars();
      }
    } catch (error) {
      console.error('Error fetching resources:', error);
    }
  }, 5000); // Update every 5 seconds
}

function stopResourceMonitoring() {
  if (consoleInterval) {
    clearInterval(consoleInterval);
    consoleInterval = null;
  }
}

async function serverAction(action) {
  if (!currentServer) return;
  
  try {
    const response = await fetch(`/api/pterodactyl/servers/${currentServer.id}/power/${action}`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('token')}`
      }
    });
    
    const data = await response.json();
    
    if (data.success) {
      showNotification(`Server ${action} action initiated`, 'success');
      // Refresh server details after a delay
      setTimeout(() => {
        openServerDetails(currentServer.id);
        loadServers();
      }, 2000);
    } else {
      showError('Failed to perform server action');
    }
  } catch (error) {
    console.error('Error performing server action:', error);
    showError('Error performing server action');
  }
}

async function quickAction(serverId, action) {
  try {
    const response = await fetch(`/api/pterodactyl/servers/${serverId}/power/${action}`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('token')}`
      }
    });
    
    const data = await response.json();
    
    if (data.success) {
      showNotification(`Server ${action} action initiated`, 'success');
      setTimeout(loadServers, 2000);
    } else {
      showError('Failed to perform server action');
    }
  } catch (error) {
    console.error('Error performing quick action:', error);
    showError('Error performing server action');
  }
}

function openConsole() {
  if (!currentServer) return;
  
  document.getElementById('consoleModal').classList.add('show');
  document.body.style.overflow = 'hidden';
  
  // Load console history
  loadConsoleHistory();
  startConsoleMonitoring();
}

function closeConsoleModal() {
  document.getElementById('consoleModal').classList.remove('show');
  document.body.style.overflow = '';
  stopConsoleMonitoring();
}

async function loadConsoleHistory() {
  if (!currentServer) return;
  
  try {
    const response = await fetch(`/api/pterodactyl/servers/${currentServer.id}/console`, {
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('token')}`
      }
    });
    
    const data = await response.json();
    
    if (data.success) {
      const output = document.getElementById('consoleOutput');
      output.textContent = data.data;
      output.scrollTop = output.scrollHeight;
    }
  } catch (error) {
    console.error('Error loading console:', error);
  }
}

function startConsoleMonitoring() {
  if (!currentServer) return;
  
  // WebSocket for real-time console would be implemented here
  // For now, we'll poll every 2 seconds
  stopConsoleMonitoring();
  
  consoleInterval = setInterval(async () => {
    await loadConsoleHistory();
  }, 2000);
}

function stopConsoleMonitoring() {
  if (consoleInterval) {
    clearInterval(consoleInterval);
    consoleInterval = null;
  }
}

async function sendCommand() {
  if (!currentServer) return;
  
  const input = document.getElementById('commandInput');
  const command = input.value.trim();
  
  if (!command) return;
  
  try {
    const response = await fetch(`/api/pterodactyl/servers/${currentServer.id}/command`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('token')}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ command })
    });
    
    const data = await response.json();
    
    if (data.success) {
      input.value = '';
      showNotification('Command sent successfully', 'success');
    } else {
      showError('Failed to send command');
    }
  } catch (error) {
    console.error('Error sending command:', error);
    showError('Error sending command');
  }
}

function openBackups() {
  if (!currentServer) return;
  
  document.getElementById('backupsModal').classList.add('show');
  document.body.style.overflow = 'hidden';
  
  loadBackups();
}

function closeBackupsModal() {
  document.getElementById('backupsModal').classList.remove('show');
  document.body.style.overflow = '';
}

async function loadBackups() {
  if (!currentServer) return;
  
  try {
    const response = await fetch(`/api/pterodactyl/servers/${currentServer.id}/backups`, {
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('token')}`
      }
    });
    
    const data = await response.json();
    
    if (data.success) {
      renderBackups(data.data);
    } else {
      showError('Failed to load backups');
    }
  } catch (error) {
    console.error('Error loading backups:', error);
    showError('Error loading backups');
  }
}

function renderBackups(backups) {
  const list = document.getElementById('backupsList');
  
  if (backups.length === 0) {
    list.innerHTML = '<p class="text-center">No backups available</p>';
    return;
  }
  
  list.innerHTML = backups.map(backup => `
    <div class="backup-item">
      <div class="backup-info">
        <div class="backup-name">${backup.name}</div>
        <div class="backup-meta">
          Created: ${new Date(backup.created_at).toLocaleString()}
          ${backup.completed_at ? ` • Completed: ${new Date(backup.completed_at).toLocaleString()}` : ' • In Progress'}
        </div>
      </div>
      <div class="backup-actions">
        <button class="btn btn-outline btn-sm" onclick="downloadBackup('${backup.uuid}')">
          <i class="fas fa-download"></i>
        </button>
        <button class="btn btn-danger btn-sm" onclick="deleteBackup('${backup.uuid}')">
          <i class="fas fa-trash"></i>
        </button>
      </div>
    </div>
  `).join('');
}

async function createBackup() {
  if (!currentServer) return;
  
  try {
    const response = await fetch(`/api/pterodactyl/servers/${currentServer.id}/backups`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('token')}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        name: `Backup ${new Date().toISOString()}`
      })
    });
    
    const data = await response.json();
    
    if (data.success) {
      showNotification('Backup creation started', 'success');
      setTimeout(loadBackups, 2000);
    } else {
      showError('Failed to create backup');
    }
  } catch (error) {
    console.error('Error creating backup:', error);
    showError('Error creating backup');
  }
}

function setupEventListeners() {
  // Search and filters
  document.getElementById('serverSearch').addEventListener('input', renderServers);
  document.getElementById('statusFilter').addEventListener('change', renderServers);
  document.getElementById('typeFilter').addEventListener('change', renderServers);
  
  // Command input
  document.getElementById('commandInput').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      sendCommand();
    }
  });
  
  // Close modals on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeServerModal();
      closeConsoleModal();
      closeBackupsModal();
    }
  });
}

function showLoadingState() {
  document.getElementById('loadingState').style.display = 'block';
  document.getElementById('serversGrid').style.display = 'none';
  document.getElementById('emptyState').style.display = 'none';
}

function hideLoadingState() {
  document.getElementById('loadingState').style.display = 'none';
  document.getElementById('serversGrid').style.display = 'grid';
}

function showEmptyState() {
  document.getElementById('emptyState').style.display = 'block';
  document.getElementById('serversGrid').style.display = 'none';
}

function hideEmptyState() {
  document.getElementById('emptyState').style.display = 'none';
}

function createServer() {
  // Redirect to server creation page or open modal
  showNotification('Server creation feature coming soon!', 'info');
}

function showNotification(message, type) {
  // Use the global notification system
  if (window.craftpick) {
    window.craftpick.showNotification(message, type);
  } else {
    alert(message);
  }
}

function showError(message) {
  showNotification(message, 'error');
}
</script>
