{{> client-nav}}

<div class="minecraft-servers-page">
  <!-- Page Header -->
  <div class="page-header">
    <div class="container">
      <div class="page-header-content">
        <div class="page-title-section">
          <h1 class="page-title">Serveurs Minecraft</h1>
          <p class="page-subtitle">Gérez vos serveurs Minecraft avec Pterodactyl</p>
        </div>
        <div class="page-actions">
          <button class="btn btn-primary" onclick="createServer()">
            <i class="fas fa-plus"></i> Nouveau Serveur
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Servers Content -->
  <div class="servers-content">
    <div class="container">
      <!-- Server Stats -->
      <div class="server-stats">
        <div class="stat-card">
          <div class="stat-icon">
            <i class="fas fa-server"></i>
          </div>
          <div class="stat-info">
            <h3 class="stat-number" id="totalServers">0</h3>
            <p class="stat-label">Serveurs Total</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon online">
            <i class="fas fa-play-circle"></i>
          </div>
          <div class="stat-info">
            <h3 class="stat-number" id="onlineServers">0</h3>
            <p class="stat-label">En Ligne</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon offline">
            <i class="fas fa-stop-circle"></i>
          </div>
          <div class="stat-info">
            <h3 class="stat-number" id="offlineServers">0</h3>
            <p class="stat-label">Hors Ligne</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">
            <i class="fas fa-microchip"></i>
          </div>
          <div class="stat-info">
            <h3 class="stat-number" id="totalRAM">0 GB</h3>
            <p class="stat-label">RAM Utilisée</p>
          </div>
        </div>
      </div>

      <!-- Server Filters -->
      <div class="server-filters">
        <div class="filter-group">
          <label>Recherche:</label>
          <input type="text" id="serverSearch" placeholder="Rechercher un serveur...">
        </div>
        <div class="filter-group">
          <label>Statut:</label>
          <select id="statusFilter">
            <option value="">Tous</option>
            <option value="running">En ligne</option>
            <option value="offline">Hors ligne</option>
            <option value="starting">Démarrage</option>
            <option value="stopping">Arrêt</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Type:</label>
          <select id="typeFilter">
            <option value="">Tous</option>
            <option value="vanilla">Vanilla</option>
            <option value="spigot">Spigot</option>
            <option value="paper">Paper</option>
            <option value="forge">Forge</option>
            <option value="fabric">Fabric</option>
          </select>
        </div>
      </div>

      <!-- Servers Grid -->
      <div class="servers-grid" id="serversGrid">
        <!-- Servers will be loaded here -->
      </div>

      <!-- Loading State -->
      <div class="loading-state" id="loadingState" style="display: none;">
        <div class="loading-spinner">
          <i class="fas fa-spinner fa-spin"></i>
          <p>Chargement des serveurs...</p>
        </div>
      </div>

      <!-- Empty State -->
      <div class="empty-state" id="emptyState" style="display: none;">
        <div class="empty-content">
          <i class="fas fa-server"></i>
          <h3>Aucun serveur trouvé</h3>
          <p>Créez votre premier serveur Minecraft pour commencer</p>
          <button class="btn btn-primary" onclick="createServer()">
            <i class="fas fa-plus"></i> Créer un Serveur
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Server Details Modal -->
<div class="modal" id="serverModal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">Détails du Serveur</h3>
      <button class="modal-close" onclick="closeServerModal()">&times;</button>
    </div>
    <div class="modal-body">
      <div class="server-details">
        <div class="detail-section">
          <h4>Informations Générales</h4>
          <div class="detail-grid">
            <div class="detail-item">
              <label>Nom:</label>
              <span id="detailName">-</span>
            </div>
            <div class="detail-item">
              <label>UUID:</label>
              <span id="detailUUID">-</span>
            </div>
            <div class="detail-item">
              <label>Statut:</label>
              <span id="detailStatus">-</span>
            </div>
            <div class="detail-item">
              <label>Node:</label>
              <span id="detailNode">-</span>
            </div>
          </div>
        </div>

        <div class="detail-section">
          <h4>Ressources</h4>
          <div class="resource-bars">
            <div class="resource-bar">
              <label>CPU:</label>
              <div class="bar-container">
                <div class="bar-fill" id="cpuBar" style="width: 0%"></div>
                <span class="bar-text" id="cpuText">0%</span>
              </div>
            </div>
            <div class="resource-bar">
              <label>RAM:</label>
              <div class="bar-container">
                <div class="bar-fill" id="ramBar" style="width: 0%"></div>
                <span class="bar-text" id="ramText">0 MB / 0 MB</span>
              </div>
            </div>
            <div class="resource-bar">
              <label>Stockage:</label>
              <div class="bar-container">
                <div class="bar-fill" id="diskBar" style="width: 0%"></div>
                <span class="bar-text" id="diskText">0 MB / 0 MB</span>
              </div>
            </div>
          </div>
        </div>

        <div class="detail-section">
          <h4>Actions</h4>
          <div class="action-buttons">
            <button class="btn btn-success" onclick="serverAction('start')">
              <i class="fas fa-play"></i> Démarrer
            </button>
            <button class="btn btn-warning" onclick="serverAction('restart')">
              <i class="fas fa-redo"></i> Redémarrer
            </button>
            <button class="btn btn-danger" onclick="serverAction('stop')">
              <i class="fas fa-stop"></i> Arrêter
            </button>
            <button class="btn btn-outline" onclick="openConsole()">
              <i class="fas fa-terminal"></i> Console
            </button>
            <button class="btn btn-outline" onclick="openBackups()">
              <i class="fas fa-save"></i> Sauvegardes
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Console Modal -->
<div class="modal" id="consoleModal">
  <div class="modal-content large">
    <div class="modal-header">
      <h3 class="modal-title">Console du Serveur</h3>
      <button class="modal-close" onclick="closeConsoleModal()">&times;</button>
    </div>
    <div class="modal-body">
      <div class="console-container">
        <div class="console-output" id="consoleOutput">
          <!-- Console output will appear here -->
        </div>
        <div class="console-input">
          <input type="text" id="commandInput" placeholder="Entrez une commande...">
          <button class="btn btn-primary" onclick="sendCommand()">
            <i class="fas fa-paper-plane"></i> Envoyer
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Backups Modal -->
<div class="modal" id="backupsModal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">Sauvegardes</h3>
      <button class="modal-close" onclick="closeBackupsModal()">&times;</button>
    </div>
    <div class="modal-body">
      <div class="backups-container">
        <div class="backups-header">
          <button class="btn btn-primary" onclick="createBackup()">
            <i class="fas fa-plus"></i> Nouvelle Sauvegarde
          </button>
        </div>
        <div class="backups-list" id="backupsList">
          <!-- Backups will be loaded here -->
        </div>
      </div>
    </div>
  </div>
</div>

