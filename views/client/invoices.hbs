                <input type="checkbox" class="invoice-checkbox">
                <span class="invoice-number">#INV-2024-003</span>
              </td>
              <td>2024-01-01</td>
              <td>2024-02-01</td>
              <td>
                <div class="invoice-description">
                  <strong>VPS Pro</strong>
                  <span class="invoice-period">Jan 2024 - Feb 2024</span>
