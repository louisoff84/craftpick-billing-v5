                    <i class="fas fa-download"></i>
                  </button>
                  <button class="btn btn-sm btn-ghost" onclick="viewInvoice('INV-2024-002')">
                    <i class="fas fa-eye"></i>
                  </button>
                </div>
              </td>
            </tr>

            <tr class="invoice-row" data-status="overdue">
