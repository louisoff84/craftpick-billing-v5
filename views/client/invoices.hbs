                    <i class="fas fa-credit-card"></i> Pay Now
                  </button>
                  <button class="btn btn-sm btn-outline" onclick="downloadInvoice('INV-2024-003')">
                    <i class="fas fa-download"></i>
                  </button>
                  <button class="btn btn-sm btn-ghost" onclick="viewInvoice('INV-2024-003')">
                    <i class="fas fa-eye"></i>
