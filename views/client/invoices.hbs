  font-weight: 600;
  color: var(--dark);
  border-bottom: 1px solid var(--gray-lighter);
}

.invoices-table td {
  padding: var(--spacing-lg);
  border-bottom: 1px solid var(--gray-lighter);
}

.invoice-row {
  transition: background var(--transition-fast);
}

.invoice-row:hover {
  background: var(--lighter);
}

.invoice-row td {
  vertical-align: middle;
}

.invoice-checkbox {
  margin-right: var(--spacing-md);
}

.invoice-number {
  font-weight: 600;
  color: var(--dark);
}

.invoice-description strong {
  display: block;
  font-weight: 600;
  color: var(--dark);
  margin-bottom: var(--spacing-xs);
}

.invoice-period {
  font-size: 0.875rem;
  color: var(--gray);
}

.invoice-amount {
