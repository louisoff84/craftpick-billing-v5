                </div>
              </td>
              <td class="invoice-amount">€49.99</td>
              <td>
                <span class="status-badge status-paid">Paid</span>
              </td>
              <td>
                <div class="invoice-actions">
                  <button class="btn btn-sm btn-outline" onclick="downloadInvoice('INV-2023-012')">
                    <i class="fas fa-download"></i>
                  </button>
                  <button class="btn btn-sm btn-ghost" onclick="viewInvoice('INV-2023-012')">
                    <i class="fas fa-eye"></i>
