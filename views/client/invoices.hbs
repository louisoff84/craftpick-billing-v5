}

.bulk-actions-buttons {
  display: flex;
  gap: var(--spacing-sm);
}

.bulk-actions .btn {
  background: rgba(255, 255, 255, 0.2);
  color: var(--white);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.bulk-actions .btn:hover {
  background: rgba(255, 255, 255, 0.3);
}

.pagination {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: var(--spacing-xl);
  flex-wrap: wrap;
  gap: var(--spacing-md);
}

.page-numbers {
  display: flex;
  gap: var(--spacing-xs);
}

.page-dots {
  padding: 0 var(--spacing-sm);
  color: var(--gray);
}

/* Payment Modal Styles */
.modal-large {
  max-width: 800px;
}

.payment-summary {
  background: var(--lighter);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-xl);
}

.payment-summary h4 {
  margin-bottom: var(--spacing-md);
  color: var(--dark);
}

.payment-items {
  margin-bottom: var(--spacing-lg);
}

.payment-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.payment-total {
  display: flex;
  justify-content: space-between;
  font-weight: 700;
  font-size: 1.125rem;
  color: var(--dark);
  padding-top: var(--spacing-md);
  border-top: 1px solid var(--gray-lighter);
}

.payment-methods {
  margin-bottom: var(--spacing-xl);
}

.payment-methods h4 {
  margin-bottom: var(--spacing-md);
  color: var(--dark);
}

.payment-method-options {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: var(--spacing-md);
}

.payment-method-option {
  cursor: pointer;
}

.payment-method-option input[type="radio"] {
  display: none;
}

.payment-method-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-lg);
  border: 2px solid var(--gray-lighter);
  border-radius: var(--radius-lg);
  transition: all var(--transition-fast);
}

.payment-method-option input[type="radio"]:checked + .payment-method-card {
  border-color: var(--primary);
  background: var(--light);
}

.payment-method-card i {
  font-size: 1.5rem;
  color: var(--primary);
}

.card-details,
.billing-address {
  margin-bottom: var(--spacing-xl);
}

.card-details h4,
.billing-address h4 {
  margin-bottom: var(--spacing-md);
  color: var(--dark);
}

.input-group {
  position: relative;
}

.input-group i {
  position: absolute;
  left: var(--spacing-md);
  top: 50%;
  transform: translateY(-50%);
  color: var(--gray);
}

.input-group input {
  padding-left: 3rem;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-md);
}

/* Invoice Preview Styles */
.invoice-preview {
  background: var(--white);
  border: 1px solid var(--gray-lighter);
  border-radius: var(--radius-lg);
  padding: var(--spacing-2xl);
  margin-bottom: var(--spacing-xl);
}

.invoice-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacing-2xl);
  border-bottom: 2px solid var(--gray-lighter);
  padding-bottom: var(--spacing-xl);
}

.invoice-logo {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--primary);
}

.invoice-info {
  text-align: right;
}

.invoice-info h2 {
  font-size: 2rem;
  font-weight: 800;
  margin-bottom: var(--spacing-sm);
}

.invoice-parties {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-2xl);
  margin-bottom: var(--spacing-2xl);
}

.bill-to h4,
.bill-from h4 {
  font-weight: 600;
  color: var(--dark);
  margin-bottom: var(--spacing-md);
}

.bill-to p,
.bill-from p {
  margin-bottom: var(--spacing-xs);
  color: var(--gray);
}

.invoice-items table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: var(--spacing-2xl);
}

.invoice-items th {
  background: var(--lighter);
  padding: var(--spacing-md);
  text-align: left;
  font-weight: 600;
  color: var(--dark);
  border-bottom: 1px solid var(--gray-lighter);
}

.invoice-items td {
  padding: var(--spacing-md);
  border-bottom: 1px solid var(--gray-lighter);
}

.invoice-totals {
  max-width: 300px;
  margin-left: auto;
  margin-bottom: var(--spacing-2xl);
}

.totals-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.totals-row.total {
  font-weight: 700;
  font-size: 1.125rem;
  color: var(--dark);
  padding-top: var(--spacing-sm);
  border-top: 1px solid var(--gray-lighter);
}

.invoice-footer {
  text-align: center;
  color: var(--gray);
  border-top: 1px solid var(--gray-lighter);
  padding-top: var(--spacing-xl);
}

.invoice-actions {
  display: flex;
  justify-content: center;
  gap: var(--spacing-md);
}

/* Responsive Design */
@media (max-width: 768px) {
  .page-header-content {
    flex-direction: column;
    text-align: center;
  }
  
  .page-actions {
    flex-direction: column;
    width: 100%;
  }
  
  .billing-stats {
    grid-template-columns: 1fr;
  }
  
  .invoices-filters {
    flex-direction: column;
    align-items: stretch;
  }
  
  .filter-right {
    flex-direction: column;
  }
  
  .invoice-row {
    display: block;
  }
  
  .invoice-row td {
    display: block;
    padding: var(--spacing-sm);
    text-align: left;
  }
  
  .invoice-row td::before {
    content: attr(data-label);
    font-weight: 600;
    color: var(--dark);
    display: block;
    margin-bottom: var(--spacing-xs);
  }
  
  .invoice-actions {
    margin-top: var(--spacing-md);
  }
  
  .bulk-actions-content {
    flex-direction: column;
    gap: var(--spacing-md);
  }
  
  .payment-method-options {
    grid-template-columns: 1fr;
  }
  
  .form-row {
    grid-template-columns: 1fr;
  }
  
  .invoice-header {
    flex-direction: column;
    gap: var(--spacing-lg);
  }
  
  .invoice-parties {
    grid-template-columns: 1fr;
  }
  
  .invoice-items {
    overflow-x: auto;
  }
}
</style>

<script>
// Invoices Page JavaScript
function showModal(modalId) {
  const modal = document.getElementById(modalId);
  if (modal) {
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
  }
}

function closeModal(modalId) {
  const modal = document.getElementById(modalId);
  if (modal) {
    modal.classList.remove('show');
    document.body.style.overflow = '';
  }
}

function downloadInvoice(invoiceNumber) {
  window.craftpick?.showNotification(`Downloading invoice ${invoiceNumber}...`, 'info');
  
  // Simulate download
  setTimeout(() => {
    const invoiceData = {
      invoiceNumber,
      date: new Date().toISOString(),
      amount: '€29.99',
      status: 'paid'
    };
    
    const blob = new Blob([JSON.stringify(invoiceData, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `invoice-${invoiceNumber}.json`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    
    window.craftpick?.showNotification('Invoice downloaded successfully!', 'success');
  }, 1000);
}

function viewInvoice(invoiceNumber) {
  showModal('invoiceModal');
  window.craftpick?.showNotification(`Loading invoice ${invoiceNumber}...`, 'info');
}

function payInvoice(invoiceNumber) {
  showModal('paymentModal');
  window.craftpick?.showNotification(`Preparing payment for ${invoiceNumber}...`, 'info');
}

function exportInvoices() {
  window.craftpick?.showNotification('Preparing invoice export...', 'info');
  
  setTimeout(() => {
    window.craftpick?.showNotification('Invoices exported successfully!', 'success');
  }, 2000);
}

function toggleSelectAll() {
  const selectAll = document.getElementById('selectAll');
  const checkboxes = document.querySelectorAll('.invoice-checkbox');
  
  checkboxes.forEach(checkbox => {
    checkbox.checked = selectAll.checked;
  });
  
  updateBulkActions();
}

function updateBulkActions() {
  const checkedBoxes = document.querySelectorAll('.invoice-checkbox:checked');
  const bulkActions = document.getElementById('bulkActions');
  const selectedCount = document.getElementById('selectedCount');
  
  if (checkedBoxes.length > 0) {
    bulkActions.style.display = 'block';
    selectedCount.textContent = checkedBoxes.length;
  } else {
    bulkActions.style.display = 'none';
  }
}

function clearSelection() {
  const checkboxes = document.querySelectorAll('.invoice-checkbox');
  checkboxes.forEach(checkbox => {
    checkbox.checked = false;
  });
  
  document.getElementById('selectAll').checked = false;
  updateBulkActions();
}

function downloadSelected() {
  const checkedBoxes = document.querySelectorAll('.invoice-checkbox:checked');
  const invoiceNumbers = Array.from(checkedBoxes).map(cb => 
    cb.closest('tr').querySelector('.invoice-number').textContent
  );
  
  window.craftpick?.showNotification(`Downloading ${invoiceNumbers.length} invoices...`, 'info');
  
  setTimeout(() => {
    window.craftpick?.showNotification('Selected invoices downloaded!', 'success');
    clearSelection();
  }, 2000);
}

function paySelected() {
  const checkedBoxes = document.querySelectorAll('.invoice-checkbox:checked');
  const invoiceNumbers = Array.from(checkedBoxes).map(cb => 
    cb.closest('tr').querySelector('.invoice-number').textContent
  );
  
  window.craftpick?.showNotification(`Preparing payment for ${invoiceNumbers.length} invoices...`, 'info');
  
  showModal('paymentModal');
}

function changePage(direction) {
  window.craftpick?.showNotification(`Loading ${direction} page...`, 'info');
}

function printInvoice() {
  window.print();
  window.craftpick?.showNotification('Print dialog opened', 'info');
}

// Initialize invoice page
document.addEventListener('DOMContentLoaded', () => {
  // Search functionality
  const searchInput = document.getElementById('invoiceSearch');
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const searchTerm = e.target.value.toLowerCase();
      const rows = document.querySelectorAll('.invoice-row');
      
      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(searchTerm) ? '' : 'none';
      });
    });
  }
  
  // Filter functionality
  const statusFilter = document.getElementById('statusFilter');
  const dateFilter = document.getElementById('dateFilter');
  
  if (statusFilter) {
    statusFilter.addEventListener('change', filterInvoices);
  }
  
  if (dateFilter) {
    dateFilter.addEventListener('change', filterInvoices);
  }
  
  function filterInvoices() {
    const status = statusFilter.value;
    const dateRange = dateFilter.value;
    const rows = document.querySelectorAll('.invoice-row');
    
    rows.forEach(row => {
      let show = true;
      
      if (status && row.dataset.status !== status) {
        show = false;
      }
      
      // Add date filtering logic here
      
      row.style.display = show ? '' : 'none';
    });
  }
  
  // Payment method switching
  const paymentMethods = document.querySelectorAll('input[name="paymentMethod"]');
  paymentMethods.forEach(method => {
    method.addEventListener('change', (e) => {
      const cardDetails = document.getElementById('cardDetails');
      if (e.target.value === 'card') {
        cardDetails.style.display = 'block';
      } else {
        cardDetails.style.display = 'none';
      }
    });
  });
  
  // Payment form submission
  const paymentForm = document.querySelector('.payment-form');
  if (paymentForm) {
    paymentForm.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const submitBtn = e.target.querySelector('button[type="submit"]');
      const originalText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
      
      // Simulate payment processing
      setTimeout(() => {
        closeModal('paymentModal');
        window.craftpick?.showNotification('Payment processed successfully!', 'success');
        
        // Reset form
        e.target.reset();
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
        
        // Update invoice status (simulate)
        updateInvoiceStatus();
      }, 3000);
    });
  }
  
  // Card number formatting
  const cardNumberInput = document.getElementById('cardNumber');
  if (cardNumberInput) {
    cardNumberInput.addEventListener('input', (e) => {
      let value = e.target.value.replace(/\s/g, '');
      let formattedValue = value.match(/.{1,4}/g)?.join(' ') || value;
      e.target.value = formattedValue;
    });
  }
  
  // Expiry date formatting
  const expiryDateInput = document.getElementById('expiryDate');
  if (expiryDateInput) {
    expiryDateInput.addEventListener('input', (e) => {
      let value = e.target.value.replace(/\D/g, '');
      if (value.length >= 2) {
        value = value.slice(0, 2) + '/' + value.slice(2, 4);
      }
      e.target.value = value;
    });
  }
  
  // Close modals on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const openModal = document.querySelector('.modal.show');
      if (openModal) {
        openModal.classList.remove('show');
        document.body.style.overflow = '';
      }
    }
  });
  
  // Close modals on overlay click
  document.querySelectorAll('.modal').forEach(modal => {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.remove('show');
        document.body.style.overflow = '';
      }
    });
  });
});

function updateInvoiceStatus() {
  // Simulate updating invoice status after payment
  const pendingBadges = document.querySelectorAll('.status-pending');
  pendingBadges.forEach(badge => {
    if (badge.closest('tr').querySelector('.invoice-number').textContent.includes('INV-2024-002')) {
      badge.className = 'status-badge status-paid';
      badge.textContent = 'Paid';
    }
  });
}
</script>
