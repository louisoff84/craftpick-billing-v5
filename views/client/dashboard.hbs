<div class="dashboard-container">
  <!-- Dashboard Header -->
  <div class="dashboard-header">
    <div class="container">
      <div class="dashboard-header-content">
        <div class="welcome-section">
          <h1 class="welcome-title">Welcome back, {{user.firstName}}! 👋</h1>
          <p class="welcome-subtitle">Manage your hosting services and monitor your performance</p>
        </div>
        <div class="quick-actions">
          <button class="btn btn-primary" onclick="showModal('newServiceModal')">
            <i class="fas fa-plus"></i> Add Service
          </button>
          <button class="btn btn-outline" onclick="showModal('supportModal')">
            <i class="fas fa-headset"></i> Get Support
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Overview -->
  <div class="stats-overview">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card animate-fadeInUp">
          <div class="stat-icon">
            <i class="fas fa-server"></i>
          </div>
          <div class="stat-content">
            <div class="stat-number">12</div>
            <div class="stat-label">Active Services</div>
            <div class="stat-change positive">
              <i class="fas fa-arrow-up"></i> 2 this month
            </div>
          </div>
        </div>
        
        <div class="stat-card animate-fadeInUp" style="animation-delay: 0.1s">
          <div class="stat-icon">
            <i class="fas fa-globe"></i>
          </div>
          <div class="stat-content">
            <div class="stat-number">24</div>
            <div class="stat-label">Websites Hosted</div>
            <div class="stat-change positive">
              <i class="fas fa-arrow-up"></i> 5 this month
            </div>
          </div>
        </div>
        
        <div class="stat-card animate-fadeInUp" style="animation-delay: 0.2s">
          <div class="stat-icon">
            <i class="fas fa-chart-line"></i>
          </div>
          <div class="stat-content">
            <div class="stat-number">99.9%</div>
            <div class="stat-label">Uptime</div>
            <div class="stat-change neutral">
              <i class="fas fa-minus"></i> Stable
            </div>
          </div>
        </div>
        
        <div class="stat-card animate-fadeInUp" style="animation-delay: 0.3s">
          <div class="stat-icon">
            <i class="fas fa-euro-sign"></i>
          </div>
          <div class="stat-content">
            <div class="stat-number">€247</div>
            <div class="stat-label">Monthly Cost</div>
            <div class="stat-change negative">
              <i class="fas fa-arrow-up"></i> €12 increase
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Dashboard Content -->
  <div class="dashboard-content">
    <div class="container">
      <div class="dashboard-grid">
        <!-- Services Section -->
        <div class="dashboard-section">
          <div class="section-header">
            <h2 class="section-title">Your Services</h2>
            <a href="/client/services" class="btn btn-ghost btn-sm">View All</a>
          </div>
          
          <div class="services-list">
            <div class="service-item animate-fadeInUp">
              <div class="service-info">
                <div class="service-icon">
                  <i class="fas fa-globe"></i>
                </div>
                <div class="service-details">
                  <h3 class="service-name">Professional Hosting</h3>
                  <p class="service-domain">mywebsite.com</p>
                  <div class="service-status">
                    <span class="status-badge status-active">Active</span>
                    <span class="service-uptime">99.9% uptime</span>
                  </div>
                </div>
              </div>
              <div class="service-actions">
                <button class="btn btn-outline btn-sm">Manage</button>
                <button class="btn btn-ghost btn-sm">Details</button>
              </div>
            </div>

            <div class="service-item animate-fadeInUp" style="animation-delay: 0.1s">
              <div class="service-info">
                <div class="service-icon">
                  <i class="fas fa-server"></i>
                </div>
                <div class="service-details">
                  <h3 class="service-name">VPS Pro</h3>
                  <p class="service-domain">vps-12345.craftpick.com</p>
                  <div class="service-status">
                    <span class="status-badge status-active">Active</span>
                    <span class="service-uptime">100% uptime</span>
                  </div>
                </div>
              </div>
              <div class="service-actions">
                <button class="btn btn-outline btn-sm">Manage</button>
                <button class="btn btn-ghost btn-sm">Details</button>
              </div>
            </div>

            <div class="service-item animate-fadeInUp" style="animation-delay: 0.2s">
              <div class="service-info">
                <div class="service-icon">
                  <i class="fas fa-shield-alt"></i>
                </div>
                <div class="service-details">
                  <h3 class="service-name">SSL Certificate</h3>
                  <p class="service-domain">*.mywebsite.com</p>
                  <div class="service-status">
                    <span class="status-badge status-warning">Expiring Soon</span>
                    <span class="service-uptime">Expires in 15 days</span>
                  </div>
                </div>
              </div>
              <div class="service-actions">
                <button class="btn btn-primary btn-sm">Renew</button>
                <button class="btn btn-ghost btn-sm">Details</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Recent Activity -->
        <div class="dashboard-section">
          <div class="section-header">
            <h2 class="section-title">Recent Activity</h2>
            <a href="/client/activity" class="btn btn-ghost btn-sm">View All</a>
          </div>
          
          <div class="activity-list">
            <div class="activity-item">
              <div class="activity-icon">
                <i class="fas fa-plus-circle text-success"></i>
              </div>
              <div class="activity-content">
                <p class="activity-title">New service added</p>
                <p class="activity-description">Professional Hosting plan activated</p>
                <span class="activity-time">2 hours ago</span>
              </div>
            </div>

            <div class="activity-item">
              <div class="activity-icon">
                <i class="fas fa-credit-card text-info"></i>
              </div>
              <div class="activity-content">
                <p class="activity-title">Payment processed</p>
                <p class="activity-description">Monthly invoice #12345 paid</p>
                <span class="activity-time">1 day ago</span>
              </div>
            </div>

            <div class="activity-item">
              <div class="activity-icon">
                <i class="fas fa-cog text-warning"></i>
              </div>
              <div class="activity-content">
                <p class="activity-title">Service updated</p>
                <p class="activity-description">VPS configuration modified</p>
                <span class="activity-time">3 days ago</span>
              </div>
            </div>

            <div class="activity-item">
              <div class="activity-icon">
                <i class="fas fa-shield-alt text-success"></i>
              </div>
              <div class="activity-content">
                <p class="activity-title">SSL renewed</p>
                <p class="activity-description">Certificate renewed for 1 year</p>
                <span class="activity-time">1 week ago</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Quick Stats -->
        <div class="dashboard-section">
          <div class="section-header">
            <h2 class="section-title">Performance Overview</h2>
          </div>
          
          <div class="performance-metrics">
            <div class="metric-card">
              <div class="metric-header">
                <h3>Server Response Time</h3>
                <span class="metric-value">245ms</span>
              </div>
              <div class="metric-chart">
                <div class="chart-bar" style="height: 60%"></div>
              </div>
              <div class="metric-status good">
                <i class="fas fa-check-circle"></i> Excellent
              </div>
            </div>

            <div class="metric-card">
              <div class="metric-header">
                <h3>Bandwidth Usage</h3>
                <span class="metric-value">67%</span>
              </div>
              <div class="metric-chart">
                <div class="chart-bar" style="height: 67%"></div>
              </div>
              <div class="metric-status warning">
                <i class="fas fa-exclamation-triangle"></i> Monitor
              </div>
            </div>

            <div class="metric-card">
              <div class="metric-header">
                <h3>Storage Usage</h3>
                <span class="metric-value">45%</span>
              </div>
              <div class="metric-chart">
                <div class="chart-bar" style="height: 45%"></div>
              </div>
              <div class="metric-status good">
                <i class="fas fa-check-circle"></i> Normal
              </div>
            </div>
          </div>
        </div>

        <!-- Support Tickets -->
        <div class="dashboard-section">
          <div class="section-header">
            <h2 class="section-title">Support Tickets</h2>
            <a href="/client/support" class="btn btn-ghost btn-sm">View All</a>
          </div>
          
          <div class="tickets-list">
            <div class="ticket-item">
              <div class="ticket-status">
                <span class="status-badge status-open">Open</span>
              </div>
              <div class="ticket-content">
                <h4 class="ticket-title">Domain transfer issue</h4>
                <p class="ticket-description">Need help transferring my domain...</p>
                <span class="ticket-time">Updated 2 hours ago</span>
              </div>
              <div class="ticket-priority">
                <span class="priority-badge priority-high">High</span>
              </div>
            </div>

            <div class="ticket-item">
              <div class="ticket-status">
                <span class="status-badge status-pending">Pending</span>
              </div>
              <div class="ticket-content">
                <h4 class="ticket-title">SSL installation</h4>
                <p class="ticket-description">Request for SSL certificate setup...</p>
                <span class="ticket-time">Updated 1 day ago</span>
              </div>
              <div class="ticket-priority">
                <span class="priority-badge priority-medium">Medium</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modals -->
<div class="modal" id="newServiceModal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">Add New Service</h3>
      <button class="modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <div class="service-options">
        <div class="service-option">
          <div class="service-option-icon">
            <i class="fas fa-globe"></i>
          </div>
          <div class="service-option-content">
            <h4>Web Hosting</h4>
            <p>Perfect for websites and blogs</p>
            <span class="service-price">From €4.99/month</span>
          </div>
          <button class="btn btn-primary">Choose Plan</button>
        </div>

        <div class="service-option">
          <div class="service-option-icon">
            <i class="fas fa-server"></i>
          </div>
          <div class="service-option-content">
            <h4>VPS Hosting</h4>
            <p>Full control with virtual private servers</p>
            <span class="service-price">From €29.99/month</span>
          </div>
          <button class="btn btn-primary">Choose Plan</button>
        </div>

        <div class="service-option">
          <div class="service-option-icon">
            <i class="fas fa-shield-alt"></i>
          </div>
          <div class="service-option-content">
            <h4>SSL Certificates</h4>
            <p>Secure your website with HTTPS</p>
            <span class="service-price">From €49.99/year</span>
          </div>
          <button class="btn btn-primary">Choose Plan</button>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal" id="supportModal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">Get Support</h3>
      <button class="modal-close">&times;</button>
    </div>
    <div class="modal-body">
      <form class="support-form">
        <div class="form-group">
          <label for="supportType">Support Type</label>
          <select id="supportType" class="form-control">
            <option value="">Select type...</option>
            <option value="technical">Technical Support</option>
            <option value="billing">Billing Question</option>
            <option value="sales">Sales Inquiry</option>
            <option value="general">General Question</option>
          </select>
        </div>

        <div class="form-group">
          <label for="supportSubject">Subject</label>
          <input type="text" id="supportSubject" class="form-control" placeholder="Brief description of your issue">
        </div>

        <div class="form-group">
          <label for="supportMessage">Message</label>
          <textarea id="supportMessage" class="form-control" rows="5" placeholder="Describe your issue in detail..."></textarea>
        </div>

        <div class="form-group">
          <label for="supportPriority">Priority</label>
          <select id="supportPriority" class="form-control">
            <option value="low">Low</option>
            <option value="medium">Medium</option>
            <option value="high">High</option>
            <option value="urgent">Urgent</option>
          </select>
        </div>

        <div class="form-actions">
          <button type="button" class="btn btn-ghost" onclick="closeModal('supportModal')">Cancel</button>
          <button type="submit" class="btn btn-primary">Submit Ticket</button>
        </div>
      </form>
    </div>
  </div>
</div>

