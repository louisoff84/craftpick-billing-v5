<div class="payment-page">
  <!-- Page Header -->
  <div class="page-header">
    <div class="container">
      <div class="page-header-content">
        <div class="page-title-section">
          <h1 class="page-title">Paiement Sécurisé</h1>
          <p class="page-subtitle">Effectuez votre paiement en toute sécurité avec nos méthodes de paiement</p>
        </div>
        <div class="page-actions">
          <a href="/client/dashboard" class="btn btn-outline">
            <i class="fas fa-arrow-left"></i> Retour au Dashboard
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Payment Content -->
  <div class="payment-content">
    <div class="container">
      <div class="payment-grid">
        <!-- Order Summary -->
        <div class="order-summary">
          <h2 class="section-title">Récapitulatif de la Commande</h2>
          <div class="order-items">
            <div class="order-item">
              <div class="item-info">
                <div class="item-icon">
                  <i class="fas fa-server"></i>
                </div>
                <div class="item-details">
                  <h3>{{serviceName}}</h3>
                  <p class="item-description">{{serviceDescription}}</p>
                  <div class="item-meta">
                    <span class="item-period">{{billingPeriod}}</span>
                    <span class="item-duration">{{serviceDuration}}</span>
                  </div>
                </div>
              </div>
              <div class="item-price">
                <span class="price-amount">€{{amount}}</span>
                <span class="price-period">{{billingPeriod}}</span>
              </div>
            </div>
          </div>
          
          <div class="order-totals">
            <div class="total-row">
              <span>Sous-total:</span>
              <span>€{{amount}}</span>
            </div>
            <div class="total-row">
              <span>TVA (20%):</span>
              <span>€{{taxAmount}}</span>
            </div>
            <div class="total-row total">
              <span>Total:</span>
              <span>€{{totalAmount}}</span>
            </div>
          </div>
          
          <div class="order-features">
            <h4>Ce que vous obtenez:</h4>
            <ul>
              {{#each features}}
                <li><i class="fas fa-check"></i> {{this}}</li>
              {{/each}}
            </ul>
          </div>
        </div>

        <!-- Payment Methods -->
        <div class="payment-methods">
          <h2 class="section-title">Choisissez votre Méthode de Paiement</h2>
          
          <form class="payment-form" id="paymentForm">
            <div class="payment-options">
              <label class="payment-option active">
                <input type="radio" name="paymentMethod" value="paypal" checked>
                <div class="payment-card">
                  <div class="payment-header">
                    <div class="payment-icon paypal-icon">
                      <i class="fab fa-paypal"></i>
                    </div>
                    <div class="payment-info">
                      <h3>PayPal</h3>
                      <p>Paiement rapide et sécurisé</p>
                    </div>
                  </div>
                  <div class="payment-badges">
                    <span class="badge secure">Sécurisé</span>
                    <span class="badge fast">Rapide</span>
                  </div>
                </div>
              </label>

              <label class="payment-option">
                <input type="radio" name="paymentMethod" value="card">
                <div class="payment-card">
                  <div class="payment-header">
                    <div class="payment-icon card-icon">
                      <i class="fas fa-credit-card"></i>
                    </div>
                    <div class="payment-info">
                      <h3>Carte de Crédit</h3>
                      <p>Visa, Mastercard, American Express</p>
                    </div>
                  </div>
                  <div class="payment-badges">
                    <span class="badge secure">Sécurisé</span>
                    <span class="badge global">Mondial</span>
                  </div>
                </div>
              </label>

              <label class="payment-option">
                <input type="radio" name="paymentMethod" value="bank">
                <div class="payment-card">
                  <div class="payment-header">
                    <div class="payment-icon bank-icon">
                      <i class="fas fa-university"></i>
                    </div>
                    <div class="payment-info">
                      <h3>Virement Bancaire</h3>
                      <p>Transfert bancaire traditionnel</p>
                    </div>
                  </div>
                  <div class="payment-badges">
                    <span class="badge secure">Sécurisé</span>
                    <span class="badge traditional">Traditionnel</span>
                  </div>
                </div>
              </label>

              <label class="payment-option">
                <input type="radio" name="paymentMethod" value="crypto">
                <div class="payment-card">
                  <div class="payment-header">
                    <div class="payment-icon crypto-icon">
                      <i class="fab fa-bitcoin"></i>
                    </div>
                    <div class="payment-info">
                      <h3>Cryptomonnaies</h3>
                      <p>Bitcoin, Ethereum, USDT</p>
                    </div>
                  </div>
                  <div class="payment-badges">
                    <span class="badge modern">Moderne</span>
                    <span class="badge anonymous">Anonyme</span>
                  </div>
                </div>
              </label>
            </div>

            <!-- PayPal Payment Section -->
            <div class="payment-section paypal-section" id="paypalSection">
              <h3>Payer avec PayPal</h3>
              <p class="payment-description">
                Vous serez redirigé vers PayPal pour effectuer votre paiement en toute sécurité.
              </p>
              <div class="paypal-button-container" data-amount="{{totalAmount}}" data-description="{{serviceName}}">
                <!-- PayPal button will be inserted here -->
              </div>
              <div class="paypal-benefits">
                <div class="benefit-item">
                  <i class="fas fa-shield-alt"></i>
                  <span>Protection acheteur PayPal</span>
                </div>
                <div class="benefit-item">
                  <i class="fas fa-lock"></i>
                  <span>Chiffrement des données</span>
                </div>
                <div class="benefit-item">
                  <i class="fas fa-undo"></i>
                  <span>Remboursement facile</span>
                </div>
              </div>
            </div>

            <!-- Card Payment Section -->
            <div class="payment-section card-section" id="cardSection" style="display: none;">
              <h3>Payer par Carte de Crédit</h3>
              <div class="card-form">
                <div class="form-group">
                  <label for="cardNumber">Numéro de Carte</label>
                  <div class="input-group">
                    <i class="fas fa-credit-card"></i>
                    <input type="text" id="cardNumber" placeholder="1234 5678 9012 3456" maxlength="19">
                    <div class="card-icons">
                      <i class="fab fa-cc-visa"></i>
                      <i class="fab fa-cc-mastercard"></i>
                      <i class="fab fa-cc-amex"></i>
                    </div>
                  </div>
                </div>
                
                <div class="form-row">
                  <div class="form-group">
                    <label for="expiryDate">Date d'Expiration</label>
                    <input type="text" id="expiryDate" placeholder="MM/AA" maxlength="5">
                  </div>
                  <div class="form-group">
                    <label for="cvv">CVV</label>
                    <input type="text" id="cvv" placeholder="123" maxlength="4">
                  </div>
                </div>
                
                <div class="form-group">
                  <label for="cardName">Nom du Titulaire</label>
                  <input type="text" id="cardName" placeholder="John Doe">
                </div>
                
                <div class="security-info">
                  <i class="fas fa-lock"></i>
                  <span>Vos informations de paiement sont sécurisées et chiffrées</span>
                </div>
              </div>
            </div>

            <!-- Bank Transfer Section -->
            <div class="payment-section bank-section" id="bankSection" style="display: none;">
              <h3>Virement Bancaire</h3>
              <div class="bank-details">
                <div class="bank-info">
                  <h4>Coordonnées Bancaires</h4>
                  <div class="bank-field">
                    <label>Bénéficiaire:</label>
                    <span>CraftPick Hosting</span>
                  </div>
                  <div class="bank-field">
                    <label>IBAN:</label>
                    <span>FR76 3000 6000 0000 0000 0000 000</span>
                    <button class="btn btn-sm btn-outline" onclick="copyToClipboard('FR76 3000 6000 0000 0000 0000 000')">
                      <i class="fas fa-copy"></i> Copier
                    </button>
                  </div>
                  <div class="bank-field">
                    <label>BIC:</label>
                    <span>BNPAFRPP</span>
                  </div>
                  <div class="bank-field">
                    <label>Référence:</label>
                    <span>CP-{{orderId}}</span>
                    <button class="btn btn-sm btn-outline" onclick="copyToClipboard('CP-{{orderId}}')">
                      <i class="fas fa-copy"></i> Copier
                    </button>
                  </div>
                </div>
                
                <div class="bank-instructions">
                  <h4>Instructions</h4>
                  <ol>
                    <li>Effectuez un virement vers le compte ci-dessus</li>
                    <li>Indiquez la référence <strong>CP-{{orderId}}</strong></li>
                    <li>Le montant à virer est de <strong>€{{totalAmount}}</strong></li>
                    <li>Les délais de traitement sont de 1-3 jours ouvrés</li>
                  </ol>
                </div>
              </div>
            </div>

            <!-- Crypto Payment Section -->
            <div class="payment-section crypto-section" id="cryptoSection" style="display: none;">
              <h3>Payer en Cryptomonnaie</h3>
              <div class="crypto-options">
                <div class="crypto-option">
                  <div class="crypto-header">
                    <div class="crypto-icon bitcoin">
                      <i class="fab fa-bitcoin"></i>
                    </div>
                    <div class="crypto-info">
                      <h4>Bitcoin (BTC)</h4>
                      <p>Montant: {{btcAmount}} BTC</p>
                    </div>
                  </div>
                  <div class="crypto-address">
                    <label>Adresse:</label>
                    <code>bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh</code>
                    <button class="btn btn-sm btn-outline" onclick="copyToClipboard('bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh')">
                      <i class="fas fa-copy"></i> Copier
                    </button>
                  </div>
                </div>
                
                <div class="crypto-option">
                  <div class="crypto-header">
                    <div class="crypto-icon ethereum">
                      <i class="fab fa-ethereum"></i>
                    </div>
                    <div class="crypto-info">
                      <h4>Ethereum (ETH)</h4>
                      <p>Montant: {{ethAmount}} ETH</p>
                    </div>
                  </div>
                  <div class="crypto-address">
                    <label>Adresse:</label>
                    <code>0x742d35Cc6634C0532925a3b844Bc454e4438f44e</code>
                    <button class="btn btn-sm btn-outline" onclick="copyToClipboard('0x742d35Cc6634C0532925a3b844Bc454e4438f44e')">
                      <i class="fas fa-copy"></i> Copier
                    </button>
                  </div>
                </div>
                
                <div class="crypto-option">
                  <div class="crypto-header">
                    <div class="crypto-icon tether">
                      <i class="fas fa-dollar-sign"></i>
                    </div>
                    <div class="crypto-info">
                      <h4>Tether (USDT)</h4>
                      <p>Montant: {{usdtAmount}} USDT</p>
                    </div>
                  </div>
                  <div class="crypto-address">
                    <label>Adresse:</label>
                    <code>TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t</code>
                    <button class="btn btn-sm btn-outline" onclick="copyToClipboard('TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t')">
                      <i class="fas fa-copy"></i> Copier
                    </button>
                  </div>
                </div>
              </div>
              
              <div class="crypto-instructions">
                <h4>Instructions</h4>
                <ol>
                  <li>Choisissez votre cryptomonnaie préférée</li>
                  <li>Envoyez le montant exact à l'adresse indiquée</li>
                  <li>Attendez la confirmation du réseau (10-30 minutes)</li>
                  <li>Votre service sera activé automatiquement</li>
                </ol>
              </div>
            </div>

            <!-- Billing Information -->
            <div class="billing-section">
              <h3>Informations de Facturation</h3>
              <div class="billing-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="billingEmail">Email *</label>
                    <input type="email" id="billingEmail" value="{{user.email}}" required>
                  </div>
                  <div class="form-group">
                    <label for="billingPhone">Téléphone</label>
                    <input type="tel" id="billingPhone" value="{{user.phone}}" placeholder="+33 1 23 45 67 89">
                  </div>
                </div>
                
                <div class="form-group">
                  <label for="billingAddress">Adresse de Facturation</label>
                  <input type="text" id="billingAddress" placeholder="123 Rue de la République">
                </div>
                
                <div class="form-row">
                  <div class="form-group">
                    <label for="billingCity">Ville</label>
                    <input type="text" id="billingCity" placeholder="Paris">
                  </div>
                  <div class="form-group">
                    <label for="billingPostal">Code Postal</label>
                    <input type="text" id="billingPostal" placeholder="75001">
                  </div>
                </div>
                
                <div class="form-group">
                  <label for="billingCountry">Pays</label>
                  <select id="billingCountry">
                    <option value="FR" selected>France</option>
                    <option value="BE">Belgique</option>
                    <option value="CH">Suisse</option>
                    <option value="LU">Luxembourg</option>
                    <option value="MC">Monaco</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Terms and Submit -->
            <div class="terms-section">
              <div class="terms-checkbox">
                <input type="checkbox" id="termsAccepted" required>
                <label for="termsAccepted">
                  J'accepte les <a href="/terms" target="_blank">conditions générales de vente</a> et 
                  la <a href="/privacy" target="_blank">politique de confidentialité</a>
                </label>
              </div>
              
              <div class="submit-section">
                <input type="hidden" name="amount" value="{{totalAmount}}">
                <input type="hidden" name="description" value="{{serviceName}}">
                <input type="hidden" name="returnUrl" value="{{returnUrl}}">
                <input type="hidden" name="cancelUrl" value="{{cancelUrl}}">
                
                <button type="submit" class="btn btn-primary btn-lg btn-full" id="submitPayment">
                  <i class="fas fa-lock"></i> Payer €{{totalAmount}}
                </button>
                
                <div class="payment-security">
                  <i class="fas fa-shield-alt"></i>
                  <span>Paiement 100% sécurisé et chiffré</span>
                </div>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
/* Payment Page Styles */
.payment-page {
  min-height: 100vh;
  background: var(--gradient-dark);
}

.page-header {
  background: var(--gradient-primary);
  color: var(--white);
  padding: calc(80px + var(--spacing-3xl)) 0 var(--spacing-3xl);
}

.page-header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--spacing-xl);
}

.page-title {
  font-size: 2.5rem;
  font-weight: 800;
  margin-bottom: var(--spacing-sm);
}

.page-subtitle {
  font-size: 1.125rem;
  opacity: 0.9;
}

.payment-content {
  padding: var(--spacing-3xl) 0;
}

.payment-grid {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: var(--spacing-3xl);
}

/* Order Summary */
.order-summary {
  background: var(--glass-bg);
  backdrop-filter: blur(20px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-xl);
  padding: var(--spacing-2xl);
  height: fit-content;
}

.section-title {
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: var(--spacing-xl);
  color: var(--white);
}

.order-items {
  margin-bottom: var(--spacing-xl);
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--spacing-lg);
  padding: var(--spacing-lg);
  background: var(--glass-border);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
}

.item-info {
  display: flex;
  gap: var(--spacing-md);
  flex: 1;
}

.item-icon {
  width: 50px;
  height: 50px;
  background: var(--gradient-accent);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--white);
  flex-shrink: 0;
}

.item-details h3 {
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--white);
  margin-bottom: var(--spacing-xs);
}

.item-description {
  color: var(--gray);
  margin-bottom: var(--spacing-sm);
}

.item-meta {
  display: flex;
  gap: var(--spacing-md);
  font-size: 0.875rem;
}

.item-period {
  color: var(--accent);
  font-weight: 600;
}

.item-duration {
  color: var(--gray);
}

.item-price {
  text-align: right;
}

.price-amount {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--accent);
  display: block;
}

.price-period {
  font-size: 0.875rem;
  color: var(--gray);
}

.order-totals {
  border-top: 1px solid var(--glass-border);
  padding-top: var(--spacing-lg);
  margin-bottom: var(--spacing-xl);
}

.total-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
  color: var(--gray);
}

.total-row.total {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--white);
  border-top: 1px solid var(--glass-border);
  padding-top: var(--spacing-md);
  margin-top: var(--spacing-md);
}

.order-features h4 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--white);
  margin-bottom: var(--spacing-md);
}

.order-features ul {
  list-style: none;
}

.order-features li {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-xs) 0;
  color: var(--gray);
  font-size: 0.875rem;
}

.order-features i {
  color: var(--success);
}

/* Payment Methods */
.payment-methods {
  background: var(--glass-bg);
  backdrop-filter: blur(20px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-xl);
  padding: var(--spacing-2xl);
}

.payment-options {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: var(--spacing-lg);
  margin-bottom: var(--spacing-2xl);
}

.payment-option {
  cursor: pointer;
}

.payment-option input[type="radio"] {
  display: none;
}

.payment-card {
  background: var(--glass-border);
  border: 2px solid transparent;
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  transition: all var(--transition-normal);
}

.payment-option input[type="radio"]:checked + .payment-card {
  border-color: var(--accent);
  background: var(--glass-bg);
}

.payment-card:hover {
  border-color: var(--accent);
  transform: translateY(-2px);
}

.payment-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.payment-icon {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--white);
  font-size: 1.25rem;
}

.paypal-icon {
  background: #0070ba;
}

.card-icon {
  background: var(--gradient-primary);
}

.bank-icon {
  background: var(--gradient-secondary);
}

.crypto-icon {
  background: var(--gradient-accent);
}

.payment-info h3 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--white);
  margin-bottom: var(--spacing-xs);
}

.payment-info p {
  font-size: 0.875rem;
  color: var(--gray);
}

.payment-badges {
  display: flex;
  gap: var(--spacing-xs);
}

.badge {
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-full);
  font-size: 0.75rem;
  font-weight: 600;
}

.badge.secure {
  background: var(--success);
  color: var(--white);
}

.badge.fast {
  background: var(--info);
  color: var(--white);
}

.badge.global {
  background: var(--primary);
  color: var(--white);
}

.badge.traditional {
  background: var(--secondary);
  color: var(--white);
}

.badge.modern {
  background: var(--accent);
  color: var(--white);
}

.badge.anonymous {
  background: var(--gray);
  color: var(--white);
}

/* Payment Sections */
.payment-section {
  background: var(--glass-border);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xl);
  margin-bottom: var(--spacing-xl);
}

.payment-section h3 {
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--white);
  margin-bottom: var(--spacing-md);
}

.payment-description {
  color: var(--gray);
  margin-bottom: var(--spacing-lg);
}

.paypal-button-container {
  margin: var(--spacing-xl) 0;
}

.paypal-benefits {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: var(--spacing-md);
  margin-top: var(--spacing-xl);
}

.benefit-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  color: var(--gray);
  font-size: 0.875rem;
}

.benefit-item i {
  color: var(--success);
}

/* Card Form */
.card-form {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
}

.input-group {
  position: relative;
}

.input-group i {
  position: absolute;
  left: var(--spacing-md);
  top: 50%;
  transform: translateY(-50%);
  color: var(--gray);
  z-index: 1;
}

.input-group input {
  padding-left: 3rem;
}

.card-icons {
  position: absolute;
  right: var(--spacing-md);
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  gap: var(--spacing-sm);
  color: var(--gray-light);
}

.security-info {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-md);
  background: var(--glass-bg);
  border-radius: var(--radius-md);
  color: var(--gray);
  font-size: 0.875rem;
}

.security-info i {
  color: var(--success);
}

/* Bank Details */
.bank-details {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-xl);
}

.bank-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1px solid var(--glass-border);
}

.bank-field label {
  color: var(--gray);
  font-weight: 500;
}

.bank-field span {
  color: var(--white);
  font-family: var(--font-mono);
}

.bank-instructions h4 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--white);
  margin-bottom: var(--spacing-md);
}

.bank-instructions ol {
  list-style: none;
  counter-reset: bank-counter;
}

.bank-instructions li {
